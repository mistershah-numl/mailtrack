{
  "manifest_version": 3,
  "name": "EmailTracker",
  "version": "1.0.0",
  "description": "Track email opens and engagement with advanced analytics",
  "permissions": [
    "scripting",
    "activeTab",
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office365.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content-gmail.js"]
    },
    {
      "matches": ["https://outlook.live.com/*", "https://outlook.office365.com/*"],
      "js": ["content-outlook.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://mail.google.com/*", "https://outlook.live.com/*", "https://outlook.office365.com/*"]
    }
  ]
}
